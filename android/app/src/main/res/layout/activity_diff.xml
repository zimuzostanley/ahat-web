<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/bgColor">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diff"
            android:textColor="?attr/textPrimaryColor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Time labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/timeA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/timeB"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Global memory diff -->
    <TextView
        android:id="@+id/globalMemDiff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textColor="?attr/textSecondaryColor"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp" />

    <!-- State summary diff -->
    <TextView
        android:id="@+id/stateSummaryDiff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textColor="?attr/textSecondaryColor"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp" />

    <!-- State filter chips -->
    <HorizontalScrollView
        android:id="@+id/diffStateFilterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:visibility="gone"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/diffStateFilterBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <!-- Column selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Column:"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingEnd="6dp" />

        <TextView
            android:id="@+id/colPss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PSS"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

        <TextView
            android:id="@+id/colJava"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Java"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

        <TextView
            android:id="@+id/colNative"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Native"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

        <TextView
            android:id="@+id/colCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Code"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

        <TextView
            android:id="@+id/colGraphics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gfx"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

        <TextView
            android:id="@+id/colRss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RSS"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

    </LinearLayout>

    <!-- Sort selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sort:"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingEnd="6dp" />

        <TextView
            android:id="@+id/sortDelta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delta"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

        <TextView
            android:id="@+id/sortAbs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="|Delta|"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

        <TextView
            android:id="@+id/sortName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/dividerColor" />

    <!-- Diff list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>
