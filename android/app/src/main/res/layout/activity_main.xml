<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/bgColor">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ahat"
                android:textColor="?attr/textPrimaryColor"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pull to refresh"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnLog"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_info_details"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle log"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnDumps"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_save"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Saved dumps"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- Log panel (hidden by default, toggled by log button) -->
    <ScrollView
        android:id="@+id/logPanel"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:visibility="gone"
        android:background="?attr/surfaceColor"
        android:padding="8dp"
        android:fillViewport="false">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />

    </ScrollView>

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tabProcesses"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Processes"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingEnd="16dp" />

        <TextView
            android:id="@+id/tabDumps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dumps"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="14sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Process list -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Progress bar -->
    <FrameLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="?attr/surfaceColor"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/progressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </FrameLayout>

</LinearLayout>
