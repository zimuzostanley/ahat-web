<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/bgColor">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ahat"
                android:textColor="?attr/textPrimaryColor"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pull to refresh"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnLog"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_log"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle log"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_history"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Snapshot history"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btnDumps"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_dumps"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Saved dumps"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- Log panel (hidden by default, toggled by log button) -->
    <ScrollView
        android:id="@+id/logPanel"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:visibility="gone"
        android:background="?attr/surfaceColor"
        android:padding="8dp"
        android:fillViewport="false">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />

    </ScrollView>

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tabProcesses"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Processes"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingEnd="16dp" />

        <TextView
            android:id="@+id/tabDumps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dumps"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnEnrichAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enrich All"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

    <!-- Search + sort bar (visible only on Processes tab) -->
    <LinearLayout
        android:id="@+id/searchSortBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:hint="Search processes\u2026"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textColor="?attr/textPrimaryColor"
            android:textColorHint="?attr/textSecondaryColor"
            android:background="?attr/surfaceColor"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sort:"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingEnd="8dp" />

            <TextView
                android:id="@+id/sortName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/sortPid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PID"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/sortState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="State"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/sortMem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mem"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <!-- Memory column selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show:"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:paddingEnd="6dp" />

            <TextView
                android:id="@+id/colPss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PSS"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <TextView
                android:id="@+id/colJava"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Java"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <TextView
                android:id="@+id/colNative"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Native"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <TextView
                android:id="@+id/colCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Code"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <TextView
                android:id="@+id/colGraphics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gfx"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

            <TextView
                android:id="@+id/colRss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RSS"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Process list -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Progress bar -->
    <FrameLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="?attr/surfaceColor"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/progressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </FrameLayout>

</LinearLayout>
