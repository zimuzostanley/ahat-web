<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/bgColor">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/detailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textPrimaryColor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/detailPid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/detailBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_bg"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Meminfo section -->
    <LinearLayout
        android:id="@+id/meminfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/meminfoLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading memory info\u2026"
            android:textColor="?attr/textSecondaryColor"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <LinearLayout
            android:id="@+id/meminfoGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/dividerColor" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/meminfoDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />

    </ScrollView>

    <!-- Dump buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="?attr/surfaceColor"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDump"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dump Heap"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDumpBitmap"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Bitmaps"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Progress -->
    <FrameLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="?attr/surfaceColor"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/progressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textSecondaryColor"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </FrameLayout>

</LinearLayout>
